{
  "manifest_version": 3,
  "name": "Amazon Review Consistency Score",
  "version": "1.0.0",
  "description": "Scores Amazon products using rating mean, standard deviation and review count.",
  "icons": { "128": "icon.png" },
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://*.amazon.co.uk/*",
    "https://*.amazon.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html" },
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.co.uk/*",
        "https://*.amazon.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}